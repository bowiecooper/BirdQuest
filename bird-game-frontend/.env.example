# Copy to .env.local and fill in. .env.local is gitignored.
# Supabase: Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# FastAPI inference service (bird-model/serve).
# Local dev: http://localhost:8000
# Production: your Hugging Face Space URL, e.g. https://<user>-birdquest-api.hf.space
VITE_INFERENCE_API_URL=http://localhost:8000
